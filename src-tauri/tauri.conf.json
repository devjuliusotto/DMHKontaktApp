{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "height": 820,
        "minHeight": 680,
        "minWidth": 980,
        "title": "AgendaKontakte",
        "width": 1280
      }
    ]
  },
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "icon": [
      "icons/icon.ico"
    ],
    "longDescription": "AgendaKontakte verwaltet Kontakte und Gruppen lokal auf dem Windows-PC.",
    "publisher": "Diakonissenmutterhaus Aidlingen e.V.",
    "shortDescription": "Lokale Kontaktverwaltung",
    "targets": [
      "msi",
      "nsis"
    ]
  },
  "identifier": "de.dmh.agendakontakte",
  "productName": "AgendaKontakte",
  "version": "0.0.2"
}
