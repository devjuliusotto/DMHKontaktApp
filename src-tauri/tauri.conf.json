{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "height": 780,
        "minHeight": 600,
        "minWidth": 760,
        "title": "DMH Kontakte und Kalender",
        "width": 1180
      }
    ]
  },
  "build": {
    "beforeBuildCommand": "npm run build:outlook-helper && npm run build",
    "beforeDevCommand": "npm run prepare:outlook-helper && npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico"
    ],
    "longDescription": "DMH Kontakte und Kalender verwaltet Kontakte, Gruppen und Termine lokal auf dem Windows-PC.",
    "publisher": "Diakonissenmutterhaus Aidlingen e.V.",
    "resources": [
      "resources/*"
    ],
    "shortDescription": "Lokale Kontakt- und Kalenderverwaltung",
    "targets": [
      "msi",
      "nsis"
    ]
  },
  "identifier": "de.dmh.agendakontakte",
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/devjuliusotto/DMHKontaktApp/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDNUFCRkU2MTM3ODc2MTAKUldRUWRuZ1Q1cjlhdk1MaUowYzBtRTFXeXJpYURCMnhCa1pqa3FaNk55ZGdnbEFjbTJFdkh5OVAK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "productName": "DMH Kontakte und Kalender",
  "version": "0.0.15"
}
